<?php

use Contao\StringUtil;

$classes = trim('ce_vtxm_content_grid '.$this->gridClasses.' '.$this->elementClass);
$idAttribute = '' !== (string) $this->elementId ? ' id="'.StringUtil::specialchars($this->elementId).'"' : '';

?>

<div<?= $idAttribute ?> class="<?= StringUtil::specialchars($classes) ?>">
  <?php if ('' !== $this->headlineText): ?>
    <<?= $this->headlineUnit ?> class="content-grid__headline"><?= StringUtil::specialchars($this->headlineText) ?></<?= $this->headlineUnit ?>>
  <?php endif; ?>

  <div class="content-grid__inner">
    <?php foreach ($this->items as $item): ?>
      <div class="content-grid__item"><?= $item ?></div>
    <?php endforeach; ?>
  </div>
</div>
